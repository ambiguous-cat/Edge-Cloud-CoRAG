# =========================
# React 前端环境变量模板
# 作用范围：Vite + React 前端（react-frontend）
# =========================

# 本地后端基础地址
# 对应代码变量：VITE_LOCAL_API_BASE_URL
# 示例：本机 FastAPI 默认端口 8005
VITE_LOCAL_API_BASE_URL=http://localhost:8005

# 云端后端基础地址
# 对应代码变量：VITE_CLOUD_API_BASE_URL
# 示例：你的云服务器 API 网关地址
VITE_CLOUD_API_BASE_URL=https://api.example.com

# 兼容旧版单地址变量（可选）
# 说明：当未设置上面 local/cloud 变量时，会回退读取这个变量
# 建议：新项目优先使用 VITE_LOCAL_API_BASE_URL 与 VITE_CLOUD_API_BASE_URL
# VITE_API_BASE_URL=http://localhost:8005

# auto 模式默认目标
# 对应代码变量：VITE_AUTO_ROUTE_TARGET
# 可选值：local | cloud
# 默认行为：未设置时按 local 处理
VITE_AUTO_ROUTE_TARGET=local

# API 请求超时时间（毫秒）
# 对应代码变量：VITE_API_TIMEOUT_MS
# 要求：正整数；未设置或无效时回退到 20000
VITE_API_TIMEOUT_MS=20000

